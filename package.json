{
  "name": "@unreleased/hellojs",
  "version": "0.2.4",
  "description": "Custom TLS 1.3 + HTTP/2 + HTTP/3 client mimicking the Chrome 147 fingerprint, with a request.js-shape API.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib/",
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "test": "node --test test/unit/*.test.js",
    "test:fingerprint": "node test/fingerprint/chrome147.js",
    "test:integration": "node test/integration/httpbin.js && node test/integration/multi-server.js && node test/integration/api.js",
    "test:soak": "node --expose-gc test/soak/soak.js",
    "lint": "eslint .",
    "test:types": "./node_modules/.bin/tsc --project test/types/tsconfig.json",
    "example": "node examples/basic.js",
    "prepublishOnly": "node -e \"require('./')\""
  },
  "keywords": [
    "tls",
    "tls13",
    "http2",
    "http3",
    "quic",
    "fingerprint",
    "ja4",
    "chrome",
    "request",
    "mlkem",
    "x25519mlkem768"
  ],
  "author": "Conor Reid <hello@conorre.id>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unreleased/hellojs.git"
  },
  "bugs": {
    "url": "https://github.com/unreleased/hellojs/issues"
  },
  "homepage": "https://github.com/unreleased/hellojs#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fzstd": "^0.1.1",
    "mlkem": "^2.7.0"
  }
}
